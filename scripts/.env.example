# Copy to scripts/.env — never commit scripts/.env

# Required
SAFEWAY_SUBSCRIPTION_KEY=
SAFEWAY_USER_AGENT=
SAFEWAY_VISITOR_ID=
SAFEWAY_UUID=

# Playwright + requests: fresh Cookie from Chrome → Network → pgmsearch (fixes stuck search loading)
# SAFEWAY_COOKIE=
# VONS_COOKIE=   # from vons.com pgmsearch request (falls back to SAFEWAY_COOKIE)

# Safeway pgmsearch store context (defaults: SF store 4601 / zip 94111 / channel pickup)
# SAFEWAY_STORE_ID=4601
# SAFEWAY_ZIPCODE=94111
# SAFEWAY_CHANNEL=pickup

# Vons pgmsearch store context (defaults: San Diego store 2053 / zip 92110 / channel instore)
# VONS_VISITOR_ID=
# VONS_UUID=            # optional; working Safari captures omit uuid query param
# VONS_STORE_ID=2053
# VONS_ZIPCODE=92110
# VONS_CHANNEL=instore
# VONS_USER_AGENT=       # Safari UA from vons.com pgmsearch capture
# VONS_SUBSCRIPTION_KEY=   # optional; defaults to SAFEWAY_SUBSCRIPTION_KEY
# SAFEWAY_SEC_CH_UA="Google Chrome";v="148", "Not-A.Brand";v="8", "Chromium";v="148"
# SAFEWAY_SEC_CH_UA_MOBILE=?0
# SAFEWAY_SEC_CH_UA_PLATFORM="macOS"

# SAFEWAY_EXTRA_HEADERS={}

# Per-request timeout (seconds). Also accepts legacy SAFEWAY_TIMEOUT_SEC.
SAFEWAY_TIMEOUT_SECONDS=30
# Vons HTTP/curl timeout (defaults to 45s if unset; falls back to SAFEWAY_TIMEOUT_SECONDS)
# VONS_TIMEOUT_SECONDS=45

# Batch tuning
SAFEWAY_REQUEST_DELAY_SEC=2.5
# SAFEWAY_OUTPUT_PATH=scripts/output/safeway_search_seed.jsonl

# If Python requests still time out while Chrome returns 200 for the same URL,
# Safeway may block non-browser TLS fingerprints. Use Playwright instead:
#   pip install playwright && playwright install chromium
#   python scripts/seed_safeway_search_playwright.py --query oreo --headful
