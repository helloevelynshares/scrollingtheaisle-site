{
  "name": "scrollingtheaisle-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:price-tracker": "vite",
    "dev:family-lab": "vite --config vite.family-lab.config.ts",
    "build:family-lab": "vite build --config vite.family-lab.config.ts && node scripts/sync-family-lab-dist.mjs",
    "analyze-weekly-ad": "python3 scripts/analyze_weekly_ad.py",
    "vons-historical-low-check": "python3 scripts/analysis/vons_historical_low_check.py",
    "generate:canonical-families": "python3 scripts/generate_canonical_families.py",
    "generate:weekly-ad-prices": "python3 scripts/generate_canonical_families.py && python3 scripts/generate_weekly_ad_prices.py",
    "import:weekly-ad": "python3 scripts/import_weekly_ad.py",
    "verify:weekly-ad": "python3 scripts/import_weekly_ad.py --verify-only",
    "generate:price-tracker-seed": "python3 scripts/generate_price_tracker_seed.py && python3 scripts/generate_vons_weekly_observations_seed.py",
    "generate:vons-feed-matches": "python3 scripts/generate_vons_feed_matches.py",
    "import:costco-data": "python3 scripts/price_comparison/import_costco_data.py",
    "generate:price-comparisons": "python3 scripts/backfill_price_comparisons.py",
    "build:price-tracker": "npm run generate:weekly-ad-prices && npm run generate:price-tracker-seed && npm run generate:price-comparisons && vite build && vite build --config vite.admin.config.ts && vite build --config vite.admin-stores.config.ts && node scripts/sync-price-tracker-dist.mjs && node scripts/sync-admin-dist.mjs && node scripts/sync-admin-stores-dist.mjs && node scripts/verify-price-tracker-build.mjs",
    "verify:price-tracker": "node scripts/verify-price-tracker-build.mjs",
    "generate:homepage-preview": "node scripts/generate_homepage_preview.mjs",
    "preview:homepage": "python3 -m http.server 8000 --bind 127.0.0.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
